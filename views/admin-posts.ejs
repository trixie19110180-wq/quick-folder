<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/">QuickFolder</a>
      <form action="/admin/logout" method="post">
        <button class="link-button" type="submit">Log out</button>
      </form>
    </header>

    <main class="page">
      <section class="feed-header">
        <div>
          <h1>Admin posts</h1>
          <p>Delete public or password-protected posts.</p>
        </div>
      </section>

      <% if (posts.length === 0) { %>
        <div class="empty-state">
          <p>No posts found.</p>
        </div>
      <% } %>

      <section class="post-list" aria-label="Admin post list">
        <% posts.forEach((post) => { %>
          <article class="post-card admin-card">
            <div>
              <div class="post-row">
                <span class="type-pill"><%= post.kind === "text" ? "Text" : "Files" %></span>
                <% if (post.password_hash) { %>
                  <span class="lock-pill">Locked</span>
                <% } %>
              </div>
              <h2><a href="/p/<%= post.slug %>"><%= post.slug %></a></h2>
              <% if (post.kind === "text") { %>
                <p class="preview"><%= post.text_preview || "No preview available." %></p>
                <p class="meta"><%= formatBytes(post.text_bytes) %> of text</p>
              <% } else { %>
                <% if (post.preview_file_id) { %>
                  <img class="feed-image-preview" src="/p/<%= post.slug %>/files/<%= post.preview_file_id %>/preview" alt="">
                <% } %>
                <p class="preview"><%= post.file_count %> file<%= post.file_count === 1 ? "" : "s" %>.</p>
                <p class="meta"><%= formatBytes(post.total_file_bytes || 0) %> total</p>
              <% } %>
              <p class="meta"><%= retentionLabel(post.delete_at) %></p>
            </div>
            <form action="/admin/posts/<%= post.slug %>/delete" method="post" data-confirm="Delete this post and its files?">
              <input type="hidden" name="next" value="/admin/posts?page=<%= page %>">
              <button class="danger-button" type="submit">Delete</button>
            </form>
          </article>
        <% }) %>
      </section>

      <nav class="pagination" aria-label="Admin post pages">
        <% if (page > 1) { %>
          <a href="/admin/posts?page=<%= page - 1 %>">Previous</a>
        <% } %>
        <% if (hasNext) { %>
          <a href="/admin/posts?page=<%= page + 1 %>">Next</a>
        <% } %>
      </nav>
    </main>
  </body>
</html>
