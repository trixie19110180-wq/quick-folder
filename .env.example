PORT=3000
APP_BASE_URL=http://localhost:3000
APP_SECRET=change-this-long-random-secret

# Use /var/data on Render when attaching a persistent disk.
DATA_DIR=./data
DATABASE_PATH=
UPLOAD_DIR=
STORAGE_DRIVER=local

# Set STORAGE_DRIVER=cloudinary on Render to keep files after instance restarts.
# CLOUDINARY_URL is the easiest option, copied from your Cloudinary dashboard.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=quick-folder

MAX_FILE_SIZE_MB=50
MAX_TEXT_SIZE_MB=10
MAX_FILES_PER_POST=10

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
CLEANUP_INTERVAL_MINUTES=15

# Permanent posts are hidden unless this is set to true.
ENABLE_PERMANENT_RETENTION=false

# Admin delete dashboard. Leave blank to disable admin login.
ADMIN_USERNAME=
ADMIN_PASSWORD_1=
ADMIN_PASSWORD_2=
